#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
config_path="${OPENCLAW_CONFIG_PATH:-$repo_root/openclaw.config.json}"
port="${OPENCLAW_GATEWAY_PORT:-19001}"

export OPENCLAW_CONFIG_PATH="$config_path"

exec openclaw gateway run --allow-unconfigured --bind loopback --port "$port" "$@"
