# ChangeMass Environment Variables
# Copy this file to .env.local and fill in your values

# Google Cloud Vertex AI (Virtual Try-On API)
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
# Option 1: Use service account key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
# Option 2: Use service account key as JSON string (alternative to file)
# GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project",...}

# Replicate AI (Current Virtual Try-On Engine)
# API token from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token
# Optional: override the try-on model (defaults to cuuupid/idm-vton:...)
REPLICATE_MODEL=cuuupid/idm-vton:906425dbca90663ff5427624839572cc56ea7d380343d13e2a4c4b09d3f0c30f
# Optional: specialized model for coveralls/overalls/jumpsuit
REPLICATE_MODEL_COVERALLS=
# Optional: request timeout for creating predictions (ms)
REPLICATE_REQUEST_TIMEOUT_MS=300000
# Optional: polling interval for prediction status (ms)
REPLICATE_POLL_INTERVAL_MS=3000
# Optional: maximum total polling time before timing out (ms)
REPLICATE_MAX_POLL_TIME_MS=900000

# Try-on backend priority (CSV). Default: replicate,lightx
TRYON_BACKEND_PRIORITY=replicate,lightx
# Frontend hint (build-time)
NEXT_PUBLIC_TRYON_BACKEND_PRIORITY=replicate,lightx

# ImgBB CDN API for image storage
IMGBB_API_KEY=your_imgbb_api_key_here

# MongoDB Atlas connection string
MONGODB_URI=your_mongodb_uri_here

# Next.js configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Development mode settings
NODE_ENV=development
