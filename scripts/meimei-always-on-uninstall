#!/usr/bin/env bash
set -euo pipefail

label="${MEIMEI_ALWAYS_ON_LABEL:-com.agent.meimei.gateway}"
plist_path="$HOME/Library/LaunchAgents/$label.plist"

if [ -f "$plist_path" ]; then
  launchctl unload "$plist_path" >/dev/null 2>&1 || true
  rm -f "$plist_path"
  echo "Uninstalled always-on gateway service: $label"
else
  echo "Service plist not found: $plist_path"
fi
