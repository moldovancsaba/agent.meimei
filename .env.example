# ChangeMass Environment Variables
# Copy this file to .env.local and fill in your values

# Google Cloud Vertex AI (Virtual Try-On API)
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
# Option 1: Use service account key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
# Option 2: Use service account key as JSON string (alternative to file)
# GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project",...}

# ImgBB CDN API for image storage
IMGBB_API_KEY=your_imgbb_api_key_here

# MongoDB Atlas connection string
MONGODB_URI=your_mongodb_uri_here

# Next.js configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Development mode settings
NODE_ENV=development
